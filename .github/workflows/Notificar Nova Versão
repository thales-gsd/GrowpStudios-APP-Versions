name: Notificar Nova Versão

on:
  release:
    types: [published]

jobs:
  send-email:
    runs-on: ubuntu-latest
    steps:
      - name: Enviar E-mail de Notificação
        uses: dawidd6/action-send-mail@v3
        with:
          server_address: smtp.gmail.com
          server_port: 465
          username: ${{ secrets.EMAIL_USERNAME }}
          password: ${{ secrets.EMAIL_PASSWORD }}
          subject: "Nova Versão Disponível: ${{ github.event.release.tag_name }}"
          to: "lista-de-usuarios@exemplo.com"
          from: "Seu App <seu-email@exemplo.com>"
          body: |
            Uma nova versão do app foi lançada!
            
            Versão: ${{ github.event.release.tag_name }}
            Notas da Versão: ${{ github.event.release.body }}
            
            Clique no botão abaixo para baixar o arquivo mais recente:
            ${{ github.event.release.html_url }}
